##----- Standard Insurance Coverage :

def standard_insurance_payout(values, attachment_point=15, exhaustion_point=50, ceding_percentage=0.5):
    """
    Applies standard insurance coverage to a series of event losses.
    Coverage is event-based (resets for every event).

    Args:
        values: ($MM) List of event loss amounts.
        attachment_point: ($MM) Loss level at which coverage begins.
        exhaustion_point: ($MM) Loss level at which coverage ends.
        ceding_percentage: (-) Share of losses covered within the layer.

    Returns:
        List of insurance payouts for each event ($MM).
    """
    payouts = []

    for loss in values:
        if loss <= attachment_point:
            payout = 0
        elif loss >= exhaustion_point:
            payout = (exhaustion_point - attachment_point) * ceding_percentage
        else:
            payout = (loss - attachment_point) * ceding_percentage

        payouts.append(payout)

    return payouts

##----- PPO Coverage :

def apply_ppo_coverage(values, ppo_available, ppo_loss_trigger):
    """
    Applies PPO coverage to a series of event losses.
    PPO activates once, at the first event exceeding the trigger.

    Args:
        values: ($MM) List of event loss amounts.
        ppo_available: ($MM) Available PPO payout per event (aligned with values).
        ppo_loss_trigger: ($MM) Loss threshold to activate PPO.

    Returns:
        List of PPO payouts applied to each event ($MM).
    """
    ppo_applied = []
    ppo_triggered = False  # Flag to track if PPO has been triggered
      
    for i, loss in enumerate(values):
      if loss > ppo_loss_trigger and not ppo_triggered:
        ppo_applied.append(ppo_available[i])  # Apply available PPO coverage
        ppo_triggered = True  # Set the trigger flag
      else:
        ppo_applied.append(0)  # No coverage applied
      
    return ppo_applied

##------ CCF Coverage

def ccf_coverage(values, ccf_maximum, ccf_person, Pop_exposed):
    """
    Applies CCF coverage to a series of event losses with a total cap (no replenish).
    Coverage is cumulative and depletes as payouts are made.

    Args:
        values: ($MM) List of event loss amounts.
        ccf_maximum: ($MM) Total available CCF coverage (exhaustible).
        ccf_person: ($) Payout per affected person.
        Pop_exposed: (-) Total population exposed.

    Returns:
        List of CCF payouts applied to each event ($MM).
    """

    ccf_function = lambda loss: np.exp(0.001074 * np.log(loss * 1000) ** 3.0883 + 7.9346)

    ccf_applied = []
    remaining_cover = ccf_maximum

    for loss in values:
        if loss < (0.01 * Pop_exposed * ccf_person / 1e6) or remaining_cover <= 0:
            ccf_app = 0
        else:
            payout_raw = (ccf_function(loss) * ccf_person / 1e6)
            ccf_app = min(payout_raw, remaining_cover)
            remaining_cover -= ccf_app

        ccf_applied.append(ccf_app)

    return ccf_applied

# >>> CHANGED: helper to aggregate event-level payouts by year
def aggregate_event_values_by_year(times, values, catalogue_length):
    annual_values = np.zeros(catalogue_length)

    if len(times) == 0:
        return annual_values

    year_index = np.floor(times).astype(int)

    for y, v in zip(year_index, values):
        if 0 <= y < catalogue_length:
            annual_values[y] += v

    return annual_values

