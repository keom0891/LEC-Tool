# Método 2: ex-ante

def calibrate_LEC_AAL(Ct, L, lam, L_cut=None, tol=1e-6, max_iter=80):
    """
    Calibrate alpha for ex-ante LEC reduction to match target AAL.

    Parameters
    ----------
    Ct : float
        Target Average Annual Loss (AAL) reduction
    L : array_like
        Original loss values corresponfding to lam
    lam : array_like
        Annual exceedance rates corresponding to L
    L_cut : float, optional
        Cutoff loss above which reductions do not apply (default: max(L))
    tol : float, optional
        Tolerance for convergence
    max_iter : int, optional
        Maximum iterations for bisection

    Returns
    -------
    alpha_star : float
        Calibrated alpha
    Lr : ndarray
        Reduced losses
    AAL : float
        Achieved AAL reduced
    """
    L = np.asarray(L, float)
    lam = np.asarray(lam, float)
    L_cut = L_cut if L_cut is not None else L.max()

    def dLred(a):
        mask = L <= L_cut
        t = np.clip(1 - L[mask]/L_cut, 1e-15, 1.0)
        d = np.ones_like(L)
        d[mask] = np.clip(1 - t**a + (a*L[mask]/L_cut)*t**(a-1), 0.0, None)
        return d

    # --- AAL for given alpha ---
    C_AAL = lambda a: (abs(np.trapezoid(lam * (1 - dLred(a)), L))+abs(np.trapezoid(L, lam * (1 - dLred(a)))))/2
    C_max = (abs(np.trapezoid(lam * (L <= L_cut), L))+abs(np.trapezoid(L, lam * (L <= L_cut))))/2

    if not 0 <= Ct <= C_max + 1e-12:
        raise ValueError(f"C_target={Ct:.6g} outside feasible [0, {C_max:.6g}]")
    if Ct == 0:
        alpha_star = np.inf
    else:
        lo, hi = 0.0, 1.0
        while C_AAL(hi) > Ct and hi < 1e12:
            hi *= 2
        for _ in range(max_iter):
            mid = 0.5*(lo+hi)
            Cm = C_AAL(mid)
            if abs(Cm - Ct) <= tol * max(1.0, Ct):
                alpha_star = mid
                break
            lo, hi = (mid, hi) if Cm > Ct else (lo, mid)
        else:
            alpha_star = 0.5*(lo+hi)

    # --- Reduced losses ---
    mask = L <= L_cut
    s = np.zeros_like(L)
    if np.isfinite(alpha_star):
        s[mask] = (1 - L[mask]/L_cut)**alpha_star
    Lr = L.copy()
    Lr[mask] = L[mask] * (1 - s[mask])

    # --- Achieved AAL ---
    AAL = (abs(np.trapezoid(lam, Lr))+abs(np.trapezoid(Lr, lam)))/2

    return Lr, AAL

