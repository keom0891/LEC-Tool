                u_l = rng.random(n)
            else:
                u_t = np.empty(0)
                u_l = np.empty(0)
            row_times.append(u_t)
            row_loss.append(u_l)
        U_times.append(row_times)
        U_loss.append(row_loss)
    return N, U_times, U_loss

