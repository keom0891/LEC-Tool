# >>> CHANGED: cree una función para calcular la CDF inversa
def build_inv_cdf(lambda_loss: np.ndarray, LS: np.ndarray):
    """Create a monotone inverse-CDF (loss = F^{-1}(u))"""
    lam = np.asarray(lambda_loss, float)
    L = np.asarray(LS, float)
    lam_min = lam.max()
    cdf_vals = 1.0 - lam / lam_min
    cdf_vals = np.maximum.accumulate(cdf_vals + np.arange(1, len(cdf_vals)+1) * np.finfo(float).eps)  # enforce strict monotonicity for interp1d
    inv = interp1d(cdf_vals, L, kind='linear', bounds_error=False, fill_value=(L[0], L[-1]))
    return inv, lam_min

# >>> CHANGED: cree una función para generar números aleatorios
def make_random_streams(simulation_number: int, catalogue_length: int, lam: float, seed: int):
    """Generate common-random streams for both simulations"""
    rng = np.random.default_rng(seed)
    N = rng.poisson(lam=lam, size=(simulation_number, catalogue_length))
    U_times = []
    U_loss  = []
